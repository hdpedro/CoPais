# Capacitor - iOS platform committed for stable CI builds (like GripFlow)
# /ios
/android
/out
# Don't commit generated iOS build artifacts
/ios/App/Pods/
/ios/App/App.xcworkspace/xcuserdata/
/ios/DerivedData/
/ios/build/
COnvite_Joaquim.jpeg

.env*.local

# Apple ASC API keys (NEVER commit)
AuthKey_*.p8
*.p8

# script artifacts (generated/log)
scripts/*-output.log
scripts/subscription-review.png
scripts/app-screenshot-iphone65.png

# Google Play service account (NEVER commit)
google-service-account.json
**/google-service-account.json
