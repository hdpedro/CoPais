{
  "name": "kindar-native",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "eas-build-pre-install": "chmod -R u+w . 2>/dev/null; rm -rf node_modules 2>/dev/null; mkdir -p node_modules && chmod 755 node_modules; true",
    "start": "expo start",
    "ota:all": "node scripts/publish-ota-all-versions.mjs",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "npx playwright test",
    "test:pwa": "npx playwright test --project=pwa",
    "test:expo-web": "npx playwright test --project=expo-web",
    "test:parity": "npx playwright test --project=pwa --project=expo-web",
    "test:auth": "npx playwright test 01-auth",
    "test:nav": "npx playwright test 02-navigation",
    "test:dashboard": "npx playwright test 03-dashboard",
    "test:calendar": "npx playwright test 04-calendar",
    "test:chat": "npx playwright test 05-chat",
    "test:health": "npx playwright test 06-health",
    "test:modules": "npx playwright test 07-modules",
    "test:secondary": "npx playwright test 08-secondary",
    "test:data": "npx playwright test 09-data",
    "test:perf": "npx playwright test 10-performance",
    "test:offline": "npx playwright test 11-offline",
    "test:payments": "npx playwright test 12-payments",
    "test:stress": "npx playwright test 13-stress",
    "test:report": "npx playwright show-report tests/reports/html"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
