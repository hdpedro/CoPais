{
	"appId": "com.kindar.app",
	"appName": "Kindar",
	"webDir": "out",
	"server": {
		"url": "https://kindar.com.br",
		"cleartext": false
	},
	"ios": {
		"contentInset": "automatic",
		"allowsLinkPreview": true,
		"scrollEnabled": true,
		"scheme": "Kindar"
	},
	"plugins": {
		"StatusBar": {
			"style": "LIGHT",
			"backgroundColor": "#EEECEA"
		},
		"SplashScreen": {
			"launchAutoHide": true,
			"launchShowDuration": 2000,
			"backgroundColor": "#EEECEA",
			"showSpinner": false
		},
		"Keyboard": {
			"resize": "body",
			"resizeOnFullScreen": true
		}
	},
	"packageClassList": [
		"AppPlugin",
		"HapticsPlugin",
		"KeyboardPlugin",
		"PushNotificationsPlugin",
		"SplashScreenPlugin",
		"StatusBarPlugin"
	]
}
