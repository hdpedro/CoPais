{
  "name": "kindar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "prepare": "husky",
    "i18n:parity": "node scripts/i18n/validate-locale-parity.mjs",
    "i18n:parity:pwa": "node scripts/i18n/validate-locale-parity.mjs --pwa",
    "i18n:parity:native": "node scripts/i18n/validate-locale-parity.mjs --native",
    "i18n:char-limits": "node scripts/i18n/validate-char-limits.mjs",
    "i18n:orphans": "node scripts/i18n/validate-orphan-keys.mjs --warn-only",
    "i18n:hardcoded": "node scripts/i18n/find-hardcoded-strings.mjs --warn-only",
    "i18n:gen": "node scripts/i18n/generate-types.mjs",
    "i18n:check": "npm run i18n:parity && npm run i18n:char-limits && npm run i18n:gen"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@sentry/nextjs": "^10.45.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "groq-sdk": "^1.1.1",
    "jose": "^6.2.3",
    "next": "16.1.7",
    "openai": "^6.34.0",
    "pdf-lib": "^1.17.1",
    "postgres": "^3.4.8",
    "posthog-js": "^1.363.1",
    "posthog-node": "^5.28.5",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.10.0",
    "server-only": "^0.0.1",
    "stripe": "^22.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "docx": "^9.6.1",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "exceljs": "^4.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lighthouse": "^13.0.3",
    "lint-staged": "^16.4.0",
    "msw": "^2.12.14",
    "pg": "^8.20.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --max-warnings 0 --no-warn-ignored"
  }
}
